# Clé API Google AI Studio (https://aistudio.google.com/apikey)
# Obtenir une clé gratuite, puis la définir ici pour le dev local
GEMINI_API_KEY=your_google_ai_studio_key_here

# Ou une clé Anthropic (https://console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# Quota journalier (nombre de requêtes via la clé serveur, défaut=50)
DAILY_QUOTA=50
