{
  "name": "html-to-pdf",
  "version": "1.0.0",
  "description": "A tiny local web app to convert HTML/CSS into a PDF.\r Paste your HTML, click a button, the PDF downloads automatically.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:css": "tailwindcss -i static/css/tailwind.src.css -o static/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i static/css/tailwind.src.css -o static/css/tailwind.css --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hariss24/html-to-pdf.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/hariss24/html-to-pdf/issues"
  },
  "homepage": "https://github.com/hariss24/html-to-pdf#readme",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/cli": "^4.3.0",
    "tailwindcss": "^4.3.0"
  }
}
